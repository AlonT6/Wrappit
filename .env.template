# --- Wrappit environment variables ---
# Copy to .env.local and fill in. .env.local is git-ignored; this template is committed.

# Public OAuth client id from your Wix Headless project
# (Wix dashboard → Settings → Headless → OAuth apps). Safe to expose to the browser.
NEXT_PUBLIC_WIX_CLIENT_ID=

# Server-only secrets — NEVER prefix with NEXT_PUBLIC_, never commit real values,
# never log. In production these live only in Netlify's env settings.

# API key: create at https://manage.wix.com/account/api-keys
# (grant Wix Data + Members permissions).
WIX_API_KEY=

# Site ID: the {SITE_ID} in your project dashboard URL — wix.com/dashboard/{SITE_ID}/
WIX_SITE_ID=
